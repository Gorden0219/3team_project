 return {\r\n        baseUrl: '',\r\n        systemIntroductionDetail: {},\r\n        queryList:[\r\n          {\r\n              queryName:\"作品类别\",\r\n          },\r\n        ],\r\n        queryIndex: 0,\r\n        zuopinxinxizuopinleibie: '',\r\n        newsList: [],\r\n        zuopinxinxiRecommend: [],\r\n\r\n\r\n\r\n\r\n\r\n\t\tfriendLinkList: [],\r\n\t\tmessageForm: {},\r\n\t\tmessageRules:{\r\n\t\t\tname:[{ required: true, message: '姓名不能为空', trigger: 'blur' },],\r\n\t\t\temail:[{ required: true, message: '邮箱不能为空', trigger: 'blur' },{ validator: this.$validate.isEmail, trigger: 'blur' }],\r\n\t\t\tmobile:[{ required: true, message: '手机号不能为空', trigger: 'blur' },{ validator: this.$validate.isMobile, trigger: 'blur' }],\r\n\t\t\tcontent:[{ required: true, message: '留言内容不能为空', trigger: 'blur' },],\r\n\t\t},\r\n      }\r\n    },\r\n    created() {\r\n\t\tthis.baseUrl = this.$config.baseUrl;\r\n\t\tthis.getNewsList();\r\n\t\tthis.getSystemIntroduction();\r\n\t\tthis.getList();\r\n\t\tthis.getFriendLinkList()\r\n    },\r\n\tmounted() {\r\n\t\twindow.addEventListener('scroll', this.handleScroll)\r\n\t\tsetTimeout(()=>{\r\n\t\t\tthis.handleScroll()\r\n\t\t},100)\r\n\t\t\r\n\t\tthis.swiperChanges()\r\n\t},\r\n\tbeforeDestroy() {\r\n\t  window.removeEventListener('scroll', this.handleScroll)\r\n\t},\r\n    //方法集合\r\n    methods: {\r\n\t\tswiperChanges() {\r\n\t\t\tsetTimeout(()=>{\r\n\t\t\t},750)\r\n\t\t},\r\n\t\tmessageSave(){\r\n\t\t\tthis.$refs[\"messageForm\"].validate(valid => {\r\n\t\t\t\tif(valid) {\r\n\t\t\t\t\tthis.$http.post('onlinemessage/save', this.messageForm).then(res => {\r\n\t\t\t\t\t\tif(res.data.code == 0) {\r\n\t\t\t\t\t\t\tthis.$message({\r\n\t\t\t\t\t\t\t\tmessage: '提交成功',\r\n\t\t\t\t\t\t\t\ttype: 'success',\r\n\t\t\t\t\t\t\t\tduration: 1500,\r\n\t\t\t\t\t\t\t\tonClose: () => {\r\n\t\t\t\t\t\t\t\t\tthis.messageForm = {}\r\n\t\t\t\t\t\t\t\t\tthis.$forceUpdate()\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t});\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t})\r\n\t\t\t\t}\r\