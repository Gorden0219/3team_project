orm.shiyingrenqun\"\r\n                  clearable placeholder=\"适应人群\"></el-input>\r\n      </el-form-item>\r\n      <el-form-item :style='{\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"0\"}' label=\"功效营养\"\r\n                    prop=\"gongxiaoyingyang\">\r\n        <el-input v-model=\"ruleForm.gongxiaoyingyang\"\r\n                  clearable placeholder=\"功效营养\"></el-input>\r\n      </el-form-item>\r\n      <el-form-item :style='{\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"0\"}' label=\"菜谱详情\"\r\n                    prop=\"caipuxiangqing\">\r\n        <editor\r\n            v-model=\"ruleForm.caipuxiangqing\"\r\n            :style='{\"border\":\"1px solid #cbbae8\",\"width\":\"100%\",\"borderRadius\":\"4px\",\"height\":\"auto\"}'\r\n            action=\"file/upload\"\r\n            class=\"editor\">\r\n        </editor>\r\n      </el-form-item>\r\n\r\n      <el-form-item :style='{\"padding\":\"0\",\"margin\":\"0\"}'>\r\n        <el-button\r\n            :style='{\"border\":\"0\",\"cursor\":\"pointer\",\"padding\":\"0\",\"margin\":\"0 25%\",\"outline\":\"none\",\"color\":\"#666\",\"borderRadius\":\"10px\",\"background\":\"linear-gradient(90deg, rgba(255,233,100,1) 0%, rgba(194,248,126,1) 29%, rgba(181,233,252,1) 61%, rgba(246,172,218,1) 100%)\",\"width\":\"128px\",\"lineHeight\":\"40px\",\"fontSize\":\"14px\",\"height\":\"40px\"}'\r\n            type=\"primary\" @click=\"onSubmit\">提交\r\n        </el-button>\r\n        <el-button\r\n            :style='{\"border\":\"2px solid rgba(213, 203, 235, 1)\",\"cursor\":\"pointer\",\"padding\":\"0\",\"margin\":\"0\",\"outline\":\"none\",\"color\":\"#000\",\"borderRadius\":\"4px\",\"background\":\"rgba(255, 255, 255, 1)\",\"width\":\"128px\",\"lineHeight\":\"40px\",\"fontSize\":\"14px\",\"height\":\"40px\"}'\r\n            @click=\"back()\">返回\r\n        </el-button>\r\n      </el-form-item>\r\n    </el-form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n 