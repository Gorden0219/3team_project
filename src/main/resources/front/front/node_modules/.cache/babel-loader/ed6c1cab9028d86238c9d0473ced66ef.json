{"remainingRequest":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\babel-loader\\lib\\index.js!D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\src\\pages\\caipuxinxi\\list.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\src\\pages\\caipuxinxi\\list.vue","mtime":1773369738126},{"path":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\babel.config.js","mtime":1773369305018},{"path":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\babel-loader\\lib\\index.js","mtime":456789000000},{"path":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"D:\\软件项目管理\\饮食分享平台--论文\\springbootc71oi\\src\\main\\resources\\front\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["data","layouts","swiperIndex","baseUrl","breadcrumbItem","name","formSearch","caipumingcheng","kouwei","shiyingrenqun","gongxiaoyingyang","fenlei","hotList","dataList","total","pageSize","pageSizes","totalPage","curFenlei","isPlain","indexQueryCondition","timeRange","created","$route","query","$config","getFenlei","getList","getHotList","methods","add","path","$router","push","autoSortUrl","localStorage","getItem","$http","get","params","page","limit","then","res","code","list","ref","i","length","searchWhere","caipinfenlei","Object","assign","curChange","prevClick","nextClick","toDetail","item","detailObj","JSON","stringify"],"sources":["src/pages/caipuxinxi/list.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div\r\n        :style='{\"padding\":\"12px\",\"margin\":\"10px auto\",\"borderColor\":\"#dbd9f4\",\"borderRadius\":\"8px\",\"background\":\"#fff\",\"borderWidth\":\"0 0 2px\",\"width\":\"1200px\",\"borderStyle\":\"solid\"}'\r\n        class=\"breadcrumb-preview\">\r\n      <el-breadcrumb :separator=\"'Ξ'\"\r\n                     :style='{\"width\":\"100%\",\"margin\":\"0 auto\",\"fontSize\":\"14px\",\"lineHeight\":\"1\",\"display\":\"flex\"}'>\r\n        <el-breadcrumb-item>首页</el-breadcrumb-item>\r\n        <el-breadcrumb-item v-for=\"(item, index) in breadcrumbItem\" :key=\"index\">{{ item.name }}</el-breadcrumb-item>\r\n      </el-breadcrumb>\r\n    </div>\r\n\r\n    <div :style='{\"width\":\"1200px\",\"margin\":\"10px auto\",\"position\":\"relative\",\"background\":\"none\"}'\r\n         class=\"list-preview\">\r\n      <div\r\n          :style='{\"padding\":\"10px\",\"borderColor\":\"#dbd9f4\",\"borderRadius\":\"8px\",\"background\":\"#fff\",\"borderWidth\":\"2px 1px 1px 1px\",\"display\":\"flex\",\"width\":\"100%\",\"borderStyle\":\"solid\",\"height\":\"auto\"}'\r\n          class=\"category-1\">\r\n        <div :class=\"swiperIndex == '-1' ? 'active' : ''\" :plain=\"isPlain\" class=\"item\" @click=\"getList(1, '全部')\">\r\n          全部\r\n        </div>\r\n        <div v-for=\"(item, index) in fenlei\" :key=\"index\" :ref=\"'btn' + index\"\r\n             :class=\"swiperIndex == index ? 'active' : ''\"\r\n             class=\"item\" plain @click=\"getList(1, item, 'btn' + index)\">{{ item }}\r\n        </div>\r\n      </div>\r\n\r\n\r\n      <el-form :inline=\"true\" :model=\"formSearch\"\r\n               :style='{\"border\":\"2px solid #dbd9f4\",\"padding\":\"10px\",\"margin\":\"10px 0 0 0\",\"alignItems\":\"center\",\"borderRadius\":\"8px\",\"flexWrap\":\"wrap\",\"background\":\"#f8f8fc\",\"display\":\"flex\",\"width\":\"100%\",\"height\":\"auto\"}'\r\n               class=\"list-form-pv\">\r\n        <el-form-item :style='{\"margin\":\"10px\"}'>\r\n          <div v-if=\"true\" :style='{\"width\":\"auto\",\"padding\":\"0 10px\",\"lineHeight\":\"42px\",\"display\":\"inline-block\"}'\r\n               class=\"lable\">菜谱名称\r\n          </div>\r\n          <el-input v-model=\"formSearch.caipumingcheng\" clearable placeholder=\"菜谱名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item :style='{\"margin\":\"10px\"}'>\r\n          <div v-if=\"true\" :style='{\"width\":\"auto\",\"padding\":\"0 10px\",\"lineHeight\":\"42px\",\"display\":\"inline-block\"}'\r\n               class=\"lable\">口味\r\n          </div>\r\n          <el-input v-model=\"formSearch.kouwei\" clearable placeholder=\"口味\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item :style='{\"margin\":\"10px\"}'>\r\n          <div v-if=\"true\" :style='{\"width\":\"auto\",\"padding\":\"0 10px\",\"lineHeight\":\"42px\",\"display\":\"inline-block\"}'\r\n               class=\"lable\">适应人群\r\n          </div>\r\n          <el-input v-model=\"formSearch.shiyingrenqun\" clearable placeholder=\"适应人群\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item :style='{\"margin\":\"10px\"}'>\r\n          <div v-if=\"true\" :style='{\"width\":\"auto\",\"padding\":\"0 10px\",\"lineHeight\":\"42px\",\"display\":\"inline-block\"}'\r\n               class=\"lable\">功效营养\r\n          </div>\r\n          <el-input v-model=\"formSearch.gongxiaoyingyang\" clearable placeholder=\"功效营养\"></el-input>\r\n        </el-form-item>\r\n        <el-button v-if=\" true \"\r\n                   :style='{\"cursor\":\"pointer\",\"border\":\"0\",\"padding\":\"0px 15px\",\"margin\":\"0 10px 0 0\",\"outline\":\"none\",\"color\":\"#666\",\"borderRadius\":\"6px\",\"background\":\"linear-gradient(90deg, rgba(255,233,100,1) 0%, rgba(194,248,126,1) 29%, rgba(181,233,252,1) 61%, rgba(246,172,218,1) 100%)\",\"width\":\"auto\",\"fontSize\":\"14px\",\"lineHeight\":\"42px\",\"height\":\"42px\"}'\r\n                   type=\"primary\" @click=\"getList(1, curFenlei)\"><i v-if=\"true\"\r\n                                                                    :style='{\"color\":\"#666\",\"margin\":\"0 10px 0 0\",\"fontSize\":\"14px\"}'\r\n                                                                    class=\"el-icon-search\"></i>查询\r\n        </el-button>\r\n        <el-button v-if=\"isAuth('caipuxinxi','新增')\"\r\n                   :style='{\"cursor\":\"pointer\",\"border\":\"0\",\"padding\":\"0px 15px\",\"margin\":\"0 10px 0 0\",\"outline\":\"none\",\"color\":\"#666\",\"borderRadius\":\"6px\",\"background\":\"linear-gradient(90deg, rgba(255,233,100,1) 0%, rgba(194,248,126,1) 29%, rgba(181,233,252,1) 61%, rgba(246,172,218,1) 100%)\",\"width\":\"auto\",\"fontSize\":\"14px\",\"lineHeight\":\"42px\",\"height\":\"42px\"}'\r\n                   type=\"primary\" @click=\"add('/index/caipuxinxiAdd')\"><i v-if=\"true\"\r\n                                                                          :style='{\"color\":\"#666\",\"margin\":\"0 10px 0 0\",\"fontSize\":\"14px\"}'\r\n                                                                          class=\"el-icon-circle-plus-outline\"></i>添加\r\n        </el-button>\r\n      </el-form>\r\n\r\n      <div :style='{\"border\":\"2px solid #dbd9f4\",\"margin\":\"20px 0 0 0\",\"borderRadius\":\"8px\",\"background\":\"#fff\"}'\r\n           class=\"list\">\r\n        <!-- 样式一 -->\r\n\r\n        <!-- 样式二 -->\r\n        <div\r\n            :style='{\"width\":\"100%\",\"padding\":\"20px 32px 20px 20px\",\"flexWrap\":\"wrap\",\"justifyContent\":\"space-between\",\"display\":\"flex\",\"height\":\"auto\"}'\r\n            class=\"list2 index-pv1\">\r\n          <div\r\n              v-for=\"(item, index) in dataList\"\r\n              :key=\"index\"\r\n              :style='{\"cursor\":\"pointer\",\"padding\":\"0\",\"margin\":\"0 0 20px 0\",\"borderRadius\":\"8px\",\"background\":\"#f6f6f6\",\"display\":\"inline-block\",\"width\":\"23%\",\"fontSize\":\"0\",\"position\":\"relative\",\"height\":\"auto\"}'\r\n              class=\"list-item animation-box\" @click=\"toDetail(item)\">\r\n            <img\r\n                v-if=\"item.caipufengmian && item.caipufengmian.substr(0,4)=='http'\"\r\n                :src=\"item.caipufengmian\"\r\n                :style='{\"width\":\"calc(100% - 24px)\",\"margin\":\"12px\",\"objectFit\":\"cover\",\"borderRadius\":\"8px\",\"display\":\"inline-block\",\"height\":\"240px\"}'\r\n                class=\"image\"/>\r\n            <img\r\n                v-else\r\n                :src=\"baseUrl + (item.caipufengmian?item.caipufengmian.split(',')[0]:'')\"\r\n                :style='{\"width\":\"calc(100% - 24px)\",\"margin\":\"12px\",\"objectFit\":\"cover\",\"borderRadius\":\"8px\",\"display\":\"inline-block\",\"height\":\"240px\"}'\r\n                class=\"image\"/>\r\n            <div\r\n                :style='{\"padding\":\"0px\",\"overflow\":\"hidden\",\"borderRadius\":\"0 0 8px 8px\",\"background\":\"#f6f6f6\",\"display\":\"inline-block\",\"width\":\"100%\",\"height\":\"auto\"}'\r\n                class=\"item-info\">\r\n              <div\r\n                  :style='{\"padding\":\"0 0 0 12px\",\"margin\":\"0px 24px 4px 0\",\"whiteSpace\":\"nowrap\",\"overflow\":\"hidden\",\"color\":\"#333\",\"borderRadius\":\"0 20px 20px 0\",\"background\":\"#ede9f6\",\"lineHeight\":\"32px\",\"fontSize\":\"14px\",\"textOverflow\":\"ellipsis\"}'\r\n                  class=\"name \">菜谱名称:{{ item.caipumingcheng }}\r\n              </div>\r\n              <div\r\n                  :style='{\"padding\":\"0 0 0 12px\",\"margin\":\"0px 24px 4px 0\",\"whiteSpace\":\"nowrap\",\"overflow\":\"hidden\",\"color\":\"#333\",\"borderRadius\":\"0 20px 20px 0\",\"background\":\"#ede9f6\",\"lineHeight\":\"32px\",\"fontSize\":\"14px\",\"textOverflow\":\"ellipsis\"}'\r\n                  class=\"name \">{{ item.caipinfenlei }}\r\n              </div>\r\n              <div\r\n                  :style='{\"padding\":\"0 0 0 12px\",\"margin\":\"0px 24px 4px 0\",\"whiteSpace\":\"nowrap\",\"overflow\":\"hidden\",\"color\":\"#333\",\"borderRadius\":\"0 20px 20px 0\",\"background\":\"#ede9f6\",\"lineHeight\":\"32px\",\"fontSize\":\"14px\",\"textOverflow\":\"ellipsis\"}'\r\n                  class=\"name \">{{ item.kouwei }}\r\n              </div>\r\n              <div v-if=\"item.price\"\r\n                   :style='{\"padding\":\"0px\",\"margin\":\"0 12px 4px 0\",\"lineHeight\":\"24px\",\"fontSize\":\"12px\",\"color\":\"#d15858\",\"textAlign\":\"right\"}'\r\n                   class=\"price\"><span :style='{\"fontSize\":\"12px\"}'>￥</span>{{ item.price }}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 热门信息 -->\r\n      <div\r\n          :style='{\"border\":\"2px solid #dbd9f4\",\"margin\":\"20px 0 0\",\"borderRadius\":\"8px\",\"background\":\"#fff\",\"width\":\"100%\",\"position\":\"relative\",\"height\":\"auto\"}'\r\n          class=\"hot\">\r\n        <div\r\n            :style='{\"padding\":\"0 20px\",\"margin\":\"0 auto\",\"color\":\"#000\",\"textAlign\":\"center\",\"background\":\"url(http://codegen.caihongy.cn/20221105/bb1ea9437beb4e1da8fcd1583db2f111.png) no-repeat,radial-gradient(circle, rgba(219,217,244,1) 0%, rgba(181,177,240,1) 100%)\",\"width\":\"260px\",\"lineHeight\":\"42px\",\"fontSize\":\"24px\",\"height\":\"42px\"}'>\r\n          热门信息\r\n        </div>\r\n        <div\r\n            :style='{\"padding\":\"20px\",\"margin\":\"4px 0 0 0\",\"background\":\"none\",\"display\":\"flex\",\"width\":\"100%\",\"justifyContent\":\"space-between\",\"height\":\"auto\"}'>\r\n          <div v-for=\"item in hotList\" :key=\"item\"\r\n               :style='{\"cursor\":\"pointer\",\"width\":\"23%\",\"padding\":\"0 0 8px 0\",\"borderRadius\":\"8px\",\"background\":\"#f6f6f6\",\"height\":\"auto\"}'\r\n               @click=\"toDetail(item)\">\r\n            <img\r\n                :src=\"baseUrl + (item.caipufengmian?item.caipufengmian.split(',')[0]:'')\"\r\n                :style='{\"width\":\"calc(100% - 24px)\",\"margin\":\"12px\",\"objectFit\":\"cover\",\"borderRadius\":\"8px\",\"display\":\"block\",\"height\":\"240px\"}'\r\n                alt=\"\">\r\n            <div\r\n                :style='{\"padding\":\"0 0 0 12px\",\"margin\":\"0px 24px 4px 0\",\"color\":\"#333\",\"borderRadius\":\"0 20px 20px 0\",\"background\":\"#ede9f6\",\"lineHeight\":\"32px\",\"fontSize\":\"14px\"}'>\r\n              {{ item.caipumingcheng }}\r\n            </div>\r\n            <div\r\n                :style='{\"padding\":\"0 0 0 12px\",\"margin\":\"0px 24px 4px 0\",\"color\":\"#333\",\"borderRadius\":\"0 20px 20px 0\",\"background\":\"#ede9f6\",\"lineHeight\":\"32px\",\"fontSize\":\"14px\"}'>\r\n              {{ item.caipinfenlei }}\r\n            </div>\r\n            <div\r\n                :style='{\"padding\":\"0 0 0 12px\",\"margin\":\"0px 24px 4px 0\",\"color\":\"#333\",\"borderRadius\":\"0 20px 20px 0\",\"background\":\"#ede9f6\",\"lineHeight\":\"32px\",\"fontSize\":\"14px\"}'>\r\n              {{ item.kouwei }}\r\n            </div>\r\n            <!--<div :style='{\"padding\":\"0 10px\",\"lineHeight\":\"24px\",\"fontSize\":\"12px\",\"color\":\"#999\",\"textAlign\":\"right\",\"background\":\"none\"}'>2022-02-02</div>-->\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <el-pagination\r\n          :hide-on-single-page=\"true\"\r\n          :layout='[\"total\",\"prev\",\"pager\",\"next\",\"sizes\",\"jumper\"].join()'\r\n          :page-size=\"pageSize\"\r\n          :page-sizes=\"pageSizes\"\r\n          :pager-count=\"7\"\r\n          :style='{\"width\":\"1200px\",\"padding\":\"0\",\"margin\":\"20px auto\",\"whiteSpace\":\"nowrap\",\"color\":\"#333\",\"fontWeight\":\"500\"}'\r\n          :total=\"total\"\r\n          background\r\n          class=\"pagination\"\r\n          next-text=\">\"\r\n          prev-text=\"<\"\r\n          @current-change=\"curChange\"\r\n          @prev-click=\"prevClick\"\r\n          @next-click=\"nextClick\"\r\n      ></el-pagination>\r\n\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  //数据集合\r\n  data() {\r\n    return {\r\n      layouts: '',\r\n      swiperIndex: -1,\r\n      baseUrl: '',\r\n      breadcrumbItem: [\r\n        {\r\n          name: '菜谱信息'\r\n        }\r\n      ],\r\n      formSearch: {\r\n        caipumingcheng: '',\r\n        kouwei: '',\r\n        shiyingrenqun: '',\r\n        gongxiaoyingyang: '',\r\n      },\r\n      fenlei: [],\r\n      hotList: [],\r\n      dataList: [],\r\n      total: 1,\r\n      pageSize: 10,\r\n      pageSizes: [10, 20, 30, 50],\r\n      totalPage: 1,\r\n      curFenlei: '全部',\r\n      isPlain: false,\r\n      indexQueryCondition: '',\r\n      timeRange: []\r\n    }\r\n  },\r\n  created() {\r\n    this.indexQueryCondition = this.$route.query.indexQueryCondition ? this.$route.query.indexQueryCondition : '';\r\n    this.baseUrl = this.$config.baseUrl;\r\n    this.getFenlei();\r\n    this.getList(1, '全部');\r\n    this.getHotList();\r\n  },\r\n  //方法集合\r\n  methods: {\r\n    add(path) {\r\n      this.$router.push({path: path});\r\n    },\r\n    getHotList() {\r\n      let autoSortUrl = \"\";\r\n      autoSortUrl = \"caipuxinxi/autoSort\";\r\n      if (localStorage.getItem('Token')) {\r\n        autoSortUrl = \"caipuxinxi/autoSort2\";\r\n      }\r\n      this.$http.get(autoSortUrl, {\r\n        params: {\r\n          page: 1,\r\n          limit: 4,\r\n        }\r\n      }).then(res => {\r\n        if (res.data.code == 0) {\r\n          this.hotList = res.data.data.list;\r\n        }\r\n      })\r\n    },\r\n    getFenlei() {\r\n      this.$http.get('option/caipinfenlei/caipinfenlei').then(res => {\r\n        if (res.data.code == 0) {\r\n          this.fenlei = res.data.data;\r\n        }\r\n      });\r\n    },\r\n    getList(page, fenlei, ref = '') {\r\n      if (fenlei == '全部') this.swiperIndex = -1;\r\n      for (let i = 0; i < this.fenlei.length; i++) {\r\n        if (fenlei == this.fenlei[i]) {\r\n          this.swiperIndex = i;\r\n          break;\r\n        }\r\n      }\r\n      this.curFenlei = fenlei;\r\n      if (this.curFenlei == '全部') {\r\n        this.isPlain = false;\r\n      } else {\r\n        this.isPlain = true;\r\n      }\r\n      let params = {page, limit: this.pageSize};\r\n      let searchWhere = {};\r\n      if (this.formSearch.caipumingcheng != '') searchWhere.caipumingcheng = '%' + this.formSearch.caipumingcheng + '%';\r\n      if (this.formSearch.kouwei != '') searchWhere.kouwei = '%' + this.formSearch.kouwei + '%';\r\n      if (this.formSearch.shiyingrenqun != '') searchWhere.shiyingrenqun = '%' + this.formSearch.shiyingrenqun + '%';\r\n      if (this.formSearch.gongxiaoyingyang != '') searchWhere.gongxiaoyingyang = '%' + this.formSearch.gongxiaoyingyang + '%';\r\n      if (this.curFenlei != '全部') searchWhere.caipinfenlei = this.curFenlei;\r\n      this.$http.get('caipuxinxi/list', {params: Object.assign(params, searchWhere)}).then(res => {\r\n        if (res.data.code == 0) {\r\n          this.dataList = res.data.data.list;\r\n          this.total = res.data.data.total;\r\n          this.pageSize = res.data.data.pageSize;\r\n          this.totalPage = res.data.data.totalPage;\r\n\r\n          this.pageSizes = [this.pageSize, this.pageSize * 2, this.pageSize * 3, this.pageSize * 5];\r\n        }\r\n      });\r\n    },\r\n    curChange(page) {\r\n      this.getList(page, this.curFenlei);\r\n    },\r\n    prevClick(page) {\r\n      this.getList(page, this.curFenlei);\r\n    },\r\n    nextClick(page) {\r\n      this.getList(page, this.curFenlei);\r\n    },\r\n    toDetail(item) {\r\n      this.$router.push({path: '/index/caipuxinxiDetail', query: {detailObj: JSON.stringify(item