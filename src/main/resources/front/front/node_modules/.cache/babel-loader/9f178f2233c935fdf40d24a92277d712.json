>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"摄影标签\" prop=\"sheyingbiaoqian\">\r\n            <el-input v-model=\"ruleForm.sheyingbiaoqian\" \r\n                placeholder=\"摄影标签\" clearable :disabled=\" false  ||ro.sheyingbiaoqian\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"作品封面\" v-if=\"type!='cross' || (type=='cross' && !ro.zuopinfengmian)\" prop=\"zuopinfengmian\">\r\n            <file-upload\r\n            tip=\"点击上传作品封面\"\r\n            action=\"file/upload\"\r\n            :limit=\"3\"\r\n            :multiple=\"true\"\r\n            :fileUrls=\"ruleForm.zuopinfengmian?ruleForm.zuopinfengmian:''\"\r\n            @change=\"zuopinfengmianUploadChange\"\r\n            ></file-upload>\r\n          </el-form-item>\r\n            <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' class=\"upload\" v-else label=\"作品封面\" prop=\"zuopinfengmian\">\r\n                <img v-if=\"ruleForm.zuopinfengmian.substring(0,4)=='http'\" class=\"upload-img\" style=\"margin-right:20px;\" v-bind:key=\"index\" :src=\"ruleForm.zuopinfengmian.split(',')[0]\" width=\"100\" height=\"100\">\r\n                <img v-else class=\"upload-img\" style=\"margin-right:20px;\" v-bind:key=\"index\" v-for=\"(item,index) in ruleForm.zuopinfengmian.split(',')\" :src=\"baseUrl+item\" width=\"100\" height=\"100\">\r\n            </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"拍摄地点\" prop=\"paishedidian\">\r\n            <el-input v-model=\"ruleForm.paishedidian\" \r\n                placeholder=\"拍摄地点\" clearable :disabled=\" false  ||ro.paishedidian\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"发布日期\" prop=\"faburiqi\">\r\n              <el-date-picker\r\n\t\t\t\t  :disabled=\" false  ||ro.faburiqi\"\r\n                  format=\"yyyy 年 MM 月 dd 日\"\r\n                  value-format=\"yyyy-MM-dd\"\r\n                  v-model=\"ruleForm.faburiqi\" \r\n                  type=\"date\"\r\n                  placeholder=\"发布日期\">\r\n              </el-date-picker> \r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"光圈大小\" prop=\"guangquandaxiao\">\r\n            <el-input v-model=\"ruleForm.guangquandaxiao\" \r\n                placeholder=\"光圈大小\" clearable :disabled=\" false  ||ro.guangquandaxiao\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"快门速度\" prop=\"kuaimensudu\">\r\n            <el-input v-model=\"ruleForm.kuaimensudu\" \r\n                placeholder=\"快门速度\" clearable :disabled=\" false  ||ro.kuaimensudu\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"感光度\" prop=\"ganguangdu\">\r\n            <el-input v-model=\"ruleForm.ganguangdu\" \r\n                placeholder=\"感光度\" clearable :disabled=\" false  ||ro.ganguangdu\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"镜头焦距\" prop=\"jingtoujiaoju\">\r\n            <el-input v-model=\"ruleForm.jingtoujiaoju\" \r\n                placeholder=\"镜头焦距\" clearable :disabled=\" false  ||ro.jingtoujiaoju\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"用户名\" prop=\"yonghuming\">\r\n            <el-input v-model=\"ruleForm.yonghuming\" \r\n                placeholder=\"用户名\" clearable :disabled=\"true  ||ro.yonghuming\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item :style='{\"width\":\"48%\",\"padding\":\"10px\",\"margin\":\"0 0 10px\",\"background\":\"none\",\"display\":\"inline-block\"}' label=\"作品推文\" prop=\"zuopintuiwen\">\r\n            <editor \r\n                :style='{\"minHeight\":\"250px\",\"padding\":\"0\",\"margin\":\"0\",\"borderColor\":\"#1abc9e30\",\"backgroundColor\":\"none\",\"borderRadius\":\"0\",\"borderWidth\":\"0px\",\"width\":\"100%\",\"borderStyle\":\"solid\",\"height\":\"auto\"}'\r\n                v-model=\"ruleForm.zuopintuiwen\" \r\n                class=\"editor\" \r\n                action=\"file/upload\">\r\n            </editor>\r\n          </el-form-item>\r\n\r\n      <el-form-item :style='{\"width\":\"100%\",\"padding\":\"0\",\"margin\":\"0\",\"textAlign\":\"center\"}'>\r\n        <el-button :style='{\"border\":\"0px solid #eccc19\",\"cursor\":\"pointer\",\"padding\":\"0\",\"margin\":\"0 20px 0 0\",\"color\":\"#fff\",\"borderRadius\":\"20px\",\"background\":\"linear-gradient(to right,#f67536,#f64d36),#f64d36\",\"width\":\"128px\",\"lineHeight\":\"40px\",\"fontSize\":\"14px\",\"height\":\"40px\"}'  type=\"primary\" @click=\"onSubmit\">提交</el-button>\r\n        <el-button :style='{\"border\":\"1px solid #ccc\",\"cursor\":\"pointer\",\"padding\":\"0\",\"margin\":\"0\",\"outline\":\"none\",\"color\":\"#666\",\"borderRadius\":\"20px\",\"background\":\"none\",\"width\":\"128px\",\"lineHeight\":\"40px\",\"fontSize\":\"14px\",\"height\":\"40px\"}' @click=\"back()\">返回</el-button>\r\n      </el-form-item>\r\n    </el-form>\r\n</div>\r\n</template>\r\n\r\n<script>\r\n  export default {\r\n    data() {\r\n\t  let self = this\r\n      return {\r\n        id: '',\r\n        baseUrl: '',\r\n        ro:{\r\n\t\t\t\tzuopinmingcheng : false,\r\n\t\t\t\tzuopinleibie : false,\r\n\t\t\t\tsheyingbiaoqian : false,\r\n\t\t\t\tzuopinfengmian : false,\r\n\t\t\t\tpaishedidian : false,\r\n\t\t\t\tfaburiqi : false,\r\n\t\t\t\tguangquandaxiao : false,\r\n\t\t\t\tkuaimensudu : false,\r\n\t\t\t\tganguangdu : false,\r\n\t\t\t\tjingtoujiaoju : false,\r\n\t\t\t\tzuopintuiwen : false,\r\n\t\t\t\tyonghuming : false,\r\n\t\t\t\tsfsh : false,\r\n\t\t\t\tshhf : false,\r\n\t\t\t\tthumbsupnum : false,\r\n\t\t\t\tcrazilynum : false,\r\n\t\t\t\tclicktime : false,\r\n\t\t\t\tclicknum : false,\r\n\t\t\t\tdiscussnum : false,\r\n\t\t\t\tstoreupnum : false,\r\n        },\r\n        type: '',\r\n        userTableName: localStorage.getItem('UserTableName'),\r\n        ruleForm: {\r\n          zuopinmingcheng: '',\r\n          zuopinleibie: '',\r\n          sheyingbiaoqian: '',\r\n          zuopinfengmian: '',\r\n          paishedidian: '',\r\n          faburiqi: '',\r\n          guangquandaxiao: '',\r\n          kuaimensudu: '',\r\n          ganguangdu: '',\r\n          jingtoujiaoju: '',\r\n          zuopintuiwen: '',\r\n          yonghuming: '',\r\n          thumbsupnum: '',\r\n          crazilynum: '',\r\n          clicktime: '',\r\n          clicknum: '',\r\n          discussnum: '',\r\n          storeupnum: '',\r\n        },\r\n        zuopinleibieOptions: [],\r\n\r\n\r\n        rules: {\r\n          zuopinmingcheng: [\r\n            { required: true, message: '作品名称不能为空', trigger: 'blur' },\r\n          ],\r\n          zuopinleibie: [\r\n            { required: true, message: '作品类别不能为空', trigger: 'blur' },\r\n          ],\r\n          sheyingbiaoqian: [\r\n          ],\r\n          zuopinfengmian: [\r\n          ],\r\n          paishedidian: [\r\n          ],\r\n          faburiqi: [\r\n          ],\r\n          guangquandaxiao: [\r\n          ],\r\n          kuaimensudu: [\r\n          ],\r\n          ganguangdu: [\r\n          ],\r\n          jingtoujiaoju: [\r\n          ],\r\n          zuopintuiwen: [\r\n          ],\r\n          yonghuming: [\r\n            { required: true, message: '用户名不能为空', trigger: 'blur' },\r\n          ],\r\n          sfsh: [\r\n          ],\r\n          shhf: [\r\n          ],\r\n          thumbsupnum: [\r\n            { validator: this.$validate.isIntNumer, trigger: 'blur' },\r\n          ],\r\n          crazilynum: [\r\n            { validator: this.$validate.isIntNumer, trigger: 'blur' },\r\n          ],\r\n          clicktime: [\r\n          ],\r\n          clicknum: [\r\n            { validator: this.$validate.isIntNumer, trigger: 'blur' },\r\n          ],\r\n          discussnum: [\r\n            { validator: this.$validate.isIntNumer, trigger: 'blur' },\r\n          ],\r\n          storeupnum: [\r\n            { validator: this.$validate.isIntNumer, trigger: 'blur' },\r\n          ],\r\n        },\r\n\t\tcenterType: false,\r\n      };\r\n    },\r\n    computed: {\r\n\r\n\r\n\r\n    },\r\n    components: {\r\n    },\r\n    created() {\r\n\t\tif(this.$route.query.centerType){\r\n\t\t\tthis.centerType = true\r\n\t\t}\r\n\t  //this.bg();\r\n      let type = this.$route.query.type ? this.$route.query.type : '';\r\n      this.init(type);\r\n      this.baseUrl = this.$config.baseUrl;\r\n      this.ruleForm.faburiqi = this.getCurDate()\r\n    },\r\n    methods: {\r\n      getMakeZero(s) {\r\n          return s < 10 ? '0' + s : s;\r\n      },\r\n      // 下载\r\n      download(file){\r\n        window.open(`${file}`)\r\n      },\r\n      // 初始化\r\n      init(type) {\r\n        this.type = type;\r\n        if(type=='cross'){\r\n          var obj = JSON.parse(localStorage.getItem('crossObj'));\r\n          for (var o in obj){\r\n            if(o=='zuopinmingcheng'){\r\n              this.ruleForm.zuopinmingcheng = obj[o];\r\n              this.ro.zuopinmingcheng = true;\r\n              continue;\r\n            }\r\n            if(o=='zuopinleibie'){\r\n              this.ruleForm.zuopinleibie = obj[o];\r\n              this.ro.zuopinleibie = true;\r\n              continue;\r\n            }\r\n            if(o=='sheyingbiaoqian'){\r\n              this.ruleForm.sheyingbiaoqian = obj[o];\r\n              this.ro.sheyingbiaoqian = true;\r\n              continue;\r\n            }\r\n            if(o=='zuopinfengmian'){\r\n              this.ruleForm.zuopinfengmian = obj[o].split(\",\")[0];\r\n              this.ro.zuopinfengmian = true;\r\n              continue;\r\n            }\r\n            if(o=='paishedidian'){\r\n              this.ruleForm.paishedidian = obj[o];\r\n              this.ro.paishedidian = true;\r\n              continue;\r\n            }\r\n            if(o=='faburiqi'){\r\n              this.ruleForm.faburiqi = obj[o];\r\n              this.ro.faburiqi = true;\r\n              continue;\r\n            }\r\n            if(o=='guangquandaxiao'){\r\n              this.ruleForm.guangquandaxiao = obj[o];\r\n              this.ro.guangquandaxiao = true;\r\n              continue;\r\n            }\r\n            if(o=='kuaimensudu'){\r\n              this.ruleForm.kuaimensudu = obj[o];\r\n              this.ro.kuaimensudu = true;\r\n              continue;\r\n            }\r\n            if(o=='ganguangdu'){\r\n              this.ruleForm.ganguangdu = obj[o];\r\n              this.ro.ganguangdu = true;\r\n              continue;\r\n            }\r\n            if(o=='jingtoujiaoju'){\r\n              this.ruleForm.jingtoujiaoju = obj[o];\r\n              this.ro.jingtoujiaoju = true;\r\n              continue;\r\n            }\r\n            if(o=='zuopintuiwen'){\r\n              this.ruleForm.zuopintuiwen = obj[o];\r\n              this.ro.zuopintuiwen = true;\r\n              continue;\r\n            }\r\n    